// Finding active subscriptions on the Premium plan
db.subscriptions.find({ 
  is_active: true, 
  plan_type: "Premium" 
});

// Increasing monthly_fee by 100 for all Basic plans
db.subscriptions.updateMany(
  { plan_type: "Basic" }, 
  { $inc: { monthly_fee: 100 } }
);

// Deleting inactive accounts that expired before 2025
db.subscriptions.deleteMany({
  is_active: false,
  renewal_date: { $lt: ISODate("2025-01-01T00:00:00Z") }
});

