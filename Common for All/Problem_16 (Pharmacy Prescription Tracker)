// Finding active prescriptions that haven't expired yet
db.prescriptions.find({
  status: "Active",
  expiry_date: { $gt: ISODate("2026-04-26T00:00:00Z") }
});

// Automatically setting status to "Expired" for overdue prescriptions
db.prescriptions.updateMany(
  { expiry_date: { $lt: ISODate("2026-04-26T00:00:00Z") } },
  { $set: { status: "Expired" } }
);

// Deleting fulfilled prescriptions from before 2024
db.prescriptions.deleteMany({
  status: "Fulfilled",
  issue_date: { $lt: ISODate("2024-01-01T00:00:00Z") }
});

// Sorting by latest issue date and displaying specific fields
db.prescriptions.find(
  {}, 
  { patient_name: 1, medicine_name: 1, status: 1, _id: 0 }
).sort({ issue_date: -1 });
