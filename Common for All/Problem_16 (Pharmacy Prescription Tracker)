  { prescription_id: "RX-103", patient_name: "Robert Brown", doctor_name: "Dr. Grey", medicine_name: "Metformin", dosage: "850mg", issue_date: ISODate("2023-11-01Z"), expiry_date: ISODate("2024-05-01Z"), status: "Fulfilled" },
